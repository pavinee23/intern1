# Google Cloud Translation API Configuration
# 
# To enable file translation, set up Google Cloud credentials:
# 1. Create Google Cloud project at https://console.cloud.google.com
# 2. Enable Cloud Translation API
# 3. Create service account and download JSON key file
# 4. Set the path to your credentials file below
# 5. Restart the development server

# Path to Google Cloud service account key (JSON file)
# Example: /home/user/credentials/translation-api-key.json
GOOGLE_APPLICATION_CREDENTIALS=

# Your Google Cloud Project ID
# Example: my-translation-project-12345
GOOGLE_CLOUD_PROJECT_ID=

# OpenAI API Configuration
#
# To enable AI features (Chatbot, Document Analyzer, AI Translation):
# 1. Get API key from https://platform.openai.com
# 2. Set the key below
# 3. Restart the development server
#
# Features enabled with this key:
# - AI Chatbot Assistant
# - AI Document Analyzer
# - AI-powered translation (better quality than Google Translate)
# - AI Chat Assistant for branch communications
# - AI Analytics & Insights

# Your OpenAI API Key
# Example: sk-proj-xxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=

# MySQL Connection Pool Configuration
#
# Configure the MySQL connection pool to prevent "Too many connections" errors
# Default values are optimized for most use cases
#
# Connection Limit: Maximum number of concurrent database connections
# - Default: 10
# - Increase if you have high concurrent traffic
# - Must be less than MySQL max_connections (default: 151)
MYSQL_CONNECTION_LIMIT=10

# Queue Limit: Maximum number of queued connection requests
# - Default: 50
# - Increase if you see connection timeouts under high load
MYSQL_QUEUE_LIMIT=50

# Health Check: Monitor connection pool status
# - Endpoint: http://localhost:3001/api/health
# - Shows active/free connections and usage percentage

# Note: After setting these values, restart the server:
# npm run dev
