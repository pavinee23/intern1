# Local development environment variables
# Copy values from your actual DB credentials before running in production

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=ksystem
MYSQL_PASSWORD=Ksave2025Admin
MYSQL_DATABASE=ksystem

# Optional user DB aliases (fallback to MYSQL_* if omitted)
MYSQL_USER_HOST=127.0.0.1
MYSQL_USER_PORT=3306
MYSQL_USER_USER=ksystem
MYSQL_USER_PASSWORD=Ksave2025Admin
MYSQL_USER_DATABASE=ksystem

# T310 MQTT listener settings
# IMPORTANT: Set T310_MQTT_BROKER to this server IP/domain that T310 can reach
T310_MQTT_BROKER=127.0.0.1
T310_MQTT_PORT=1883
T310_MQTT_TOPIC=ksystem/meter/+/data
T310_MQTT_USERNAME=
T310_MQTT_PASSWORD=

# Optional DB override for T310 listener (if omitted, listener uses MYSQL_*)
T310_DB_HOST=127.0.0.1
T310_DB_USER=ksystem
T310_DB_PASSWORD=Ksave2025Admin
T310_DB_NAME=ksystem

# T310 listener health endpoint
T310_HEALTH_ENABLED=true
T310_HEALTH_PORT=8099
T310_HEALTH_STALE_SECONDS=300
